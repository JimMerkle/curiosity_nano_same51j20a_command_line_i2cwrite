# .gitignore for MPLAB X (SAM E51 Curiosity Nano) projects

# Build outputs
**/build/
**/debug/
**/dist/

# Compiler / linker artifacts
*.hex
*.elf
*.map
*.o
*.d
*.dep
*.bin
*.lst
*.zip

# MPLAB X generated / machine-specific (regenerated on build)
**/nbproject/private/
**/.generated_files/
**/nbproject/Makefile-genesis.properties
**/mcc-manifest-autosave.yml
**/mcc-manifest-generated-success.yml

# Autosave / backups / logs
*.autosave
*.save
*~
*.swp
*.bak
*.log
MPLABXLog.xml
*.lck

# IDE / editor
.vscode/
.idea/
*.suo
*.user
*.userprefs

# OS
.DS_Store
Thumbs.db

# Kept (committed): nbproject/project.xml, nbproject/configurations.xml,
# nbproject/Makefile-default.mk (and the other stable Makefile-*.mk)

# Additional MPLAB X generated Makefiles (regenerated by prjMakefilesGenerator)
**/nbproject/Makefile-impl.mk
**/nbproject/Makefile-variables.mk
**/nbproject/Makefile-local-*.mk
